{
  "name": "@arbinexus/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:vercel": "esbuild api/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/bundle.js",
    "start": "node dist/server.js",
    "lint": "echo \"No lint configured for @arbinexus/api\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arbinexus/sdk": "workspace:*",
    "@arbinexus/types": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
