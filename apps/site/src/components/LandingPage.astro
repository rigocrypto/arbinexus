---
import type { LandingContent } from './types';

const { content } = Astro.props as { content: LandingContent };
const screenshots = [
  {
    src: `${import.meta.env.BASE_URL}screenshots/dashboard-overview.png`,
    alt: 'ArbiNexus dashboard overview'
  },
  {
    src: `${import.meta.env.BASE_URL}screenshots/system-architecture.png`,
    alt: 'ArbiNexus system architecture diagram'
  },
  {
    src: `${import.meta.env.BASE_URL}brand/arbinexus-logo.png`,
    alt: 'ArbiNexus logo'
  }
];
---

<div class="page-shell">
  <section class="hero panel">
    <div class="hero-copy">
      <p class="eyebrow">{content.langLabel}</p>
      <h1>{content.headline}</h1>
      <p class="lede">{content.subheadline}</p>
      <div class="cta-row">
        <a class="button primary" href="https://youtu.be/G2c4WNlbrwI" target="_blank" rel="noreferrer">{content.ctas.demo}</a>
        <a class="button" href="https://github.com/rigocrypto/arbinexus" target="_blank" rel="noreferrer">{content.ctas.github}</a>
        <a class="button ghost" href="https://github.com/rigocrypto/arbinexus/blob/main/docs/submission-copy.md" target="_blank" rel="noreferrer">{content.ctas.docs}</a>
      </div>
      <ul class="proof-strip" aria-label={content.sections.proof}>
        {content.proofStrip.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="hero-visual panel inset">
      <img src={`${import.meta.env.BASE_URL}brand/arbinexus-logo.png`} alt="ArbiNexus brand mark" loading="eager" />
      <p>{content.footerTagline}</p>
    </div>
  </section>

  <section id="problem" class="panel split">
    <div>
      <p class="section-kicker">{content.sections.problem}</p>
      <h2>{content.problemTitle}</h2>
    </div>
    <div class="body-stack">
      {content.problemBody.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section id="how-it-works" class="panel">
    <p class="section-kicker">{content.sections.how}</p>
    <h2>{content.howTitle}</h2>
    <div class="step-grid">
      {content.howSteps.map((step, index) => (
        <article class="step-card inset">
          <span class="step-index">0{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="screenshots" class="panel">
    <div class="section-head">
      <div>
        <p class="section-kicker">{content.sections.screenshots}</p>
        <h2>{content.screenshotCaption}</h2>
      </div>
      <a class="text-link" href="https://github.com/rigocrypto/arbinexus#running-locally" target="_blank" rel="noreferrer">Local setup</a>
    </div>
    <div class="shot-grid">
      {screenshots.map((shot) => (
        <figure class="shot-card inset">
          <img src={shot.src} alt={shot.alt} loading="lazy" />
        </figure>
      ))}
    </div>
  </section>

  <section id="demo" class="panel split demo-block">
    <div>
      <p class="section-kicker">{content.sections.demo}</p>
      <h2>{content.demoBlurb}</h2>
      <p>The current MVP streams live opportunities, explains signal rationale, and lets users preview paper trades before any execution path is considered.</p>
    </div>
    <div class="video-shell inset">
      <iframe
        src="https://www.youtube.com/embed/G2c4WNlbrwI"
        title="ArbiNexus demo video"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <section id="why-arbinexus" class="panel split">
    <div>
      <p class="section-kicker">{content.sections.why}</p>
      <h2>{content.differentiatorsTitle}</h2>
    </div>
    <ul class="feature-list">
      {content.differentiators.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section id="tech-stack" class="panel stack-grid">
    <div>
      <p class="section-kicker">{content.sections.stack}</p>
      <h2>Built on the Solana data plane that matters.</h2>
    </div>
    <div class="mini-grid">
      <article class="mini-card inset"><h3>Pyth</h3><p>Fair-value reference pricing and confidence data.</p></article>
      <article class="mini-card inset"><h3>Jupiter</h3><p>Executable route-aware quotes instead of static displayed prices.</p></article>
      <article class="mini-card inset"><h3>Fastify API</h3><p>SSE streaming and simulation endpoints for live opportunity delivery.</p></article>
      <article class="mini-card inset"><h3>Next.js Dashboard</h3><p>Explainable signal UI, health indicators, and operator-friendly workflows.</p></article>
    </div>
  </section>

  <section id="roadmap" class="panel split roadmap-block">
    <div>
      <p class="section-kicker">{content.sections.roadmap}</p>
      <h2>{content.roadmapTitle}</h2>
    </div>
    <div class="roadmap-grid">
      <article class="inset">
        <h3>Near term</h3>
        <ul class="plain-list">{content.roadmapNear.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="inset">
        <h3>Long term</h3>
        <ul class="plain-list">{content.roadmapLong.map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
  </section>
</div>
