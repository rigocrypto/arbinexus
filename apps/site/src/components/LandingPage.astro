---
import type { LandingContent } from './types';

const { content } = Astro.props as { content: LandingContent };
const isEs = content.locale === 'es';
const localSetupLabel = isEs ? 'Configuración local' : 'Local setup';
const demoParagraph = isEs
  ? 'Mira cómo ArbiNexus detecta dislocaciones de precio en tiempo real comparando datos del oráculo Pyth con cotizaciones ejecutables de Jupiter.'
  : 'The current MVP streams live opportunities, explains signal rationale, and lets users preview paper trades before any execution path is considered.';
const stackTitle = isEs
  ? 'Construido sobre la capa de datos de Solana que realmente importa.'
  : 'Built on the Solana data plane that matters.';
const stackCards = isEs
  ? [
      { title: 'Pyth', body: 'Precios de referencia de valor justo y datos de confianza.' },
      { title: 'Jupiter', body: 'Cotizaciones ejecutables por ruta en lugar de precios mostrados estáticos.' },
      { title: 'API Fastify', body: 'Endpoints SSE y de simulación para distribuir oportunidades en vivo.' },
      { title: 'Dashboard Next.js', body: 'Interfaz de señales explicables, indicadores de salud y flujos orientados al operador.' }
    ]
  : [
      { title: 'Pyth', body: 'Fair-value reference pricing and confidence data.' },
      { title: 'Jupiter', body: 'Executable route-aware quotes instead of static displayed prices.' },
      { title: 'Fastify API', body: 'SSE streaming and simulation endpoints for live opportunity delivery.' },
      { title: 'Next.js Dashboard', body: 'Explainable signal UI, health indicators, and operator-friendly workflows.' }
    ];
const roadmapNearLabel = isEs ? 'Corto plazo' : 'Near term';
const roadmapLongLabel = isEs ? 'Largo plazo' : 'Long term';
const galleryLabels = isEs
  ? {
      open: 'Abrir captura',
      close: 'Cerrar',
      zoomIn: 'Acercar',
      zoomOut: 'Alejar',
      reset: 'Reiniciar vista',
      prev: 'Anterior',
      next: 'Siguiente',
      hint: 'Usa la rueda del mouse para acercar/alejar y arrastra para mover.'
    }
  : {
      open: 'Open screenshot',
      close: 'Close',
      zoomIn: 'Zoom in',
      zoomOut: 'Zoom out',
      reset: 'Reset view',
      prev: 'Previous',
      next: 'Next',
      hint: 'Use mouse wheel to zoom and drag to pan.'
    };
const screenshots = [
  {
    src: `${import.meta.env.BASE_URL}screenshots/dashboard-overview.png`,
    alt: 'ArbiNexus dashboard overview'
  },
  {
    src: `${import.meta.env.BASE_URL}screenshots/mvp-upgrades.png`,
    alt: 'ArbiNexus MVP upgrades'
  },
  {
    src: `${import.meta.env.BASE_URL}screenshots/mvp-upgrades-2.png`,
    alt: 'ArbiNexus MVP upgrades detail'
  },
  {
    src: `${import.meta.env.BASE_URL}screenshots/system-architecture.png`,
    alt: 'ArbiNexus system architecture diagram'
  },
  {
    src: `${import.meta.env.BASE_URL}brand/arbinexus-logo.png`,
    alt: 'ArbiNexus logo'
  }
];
---

<div class="page-shell">
  <section class="hero panel">
    <div class="hero-copy">
      <p class="eyebrow">{content.langLabel}</p>
      <h1>{content.headline}</h1>
      <p class="lede">{content.subheadline}</p>
      <div class="cta-row">
        <a class="button primary" href="https://youtu.be/G2c4WNlbrwI" target="_blank" rel="noreferrer">{content.ctas.demo}</a>
        <a class="button" href="https://github.com/rigocrypto/arbinexus" target="_blank" rel="noreferrer">{content.ctas.github}</a>
        <a class="button ghost" href="https://github.com/rigocrypto/arbinexus/blob/main/docs/submission-copy.md" target="_blank" rel="noreferrer">{content.ctas.docs}</a>
      </div>
      <ul class="proof-strip" aria-label={content.sections.proof}>
        {content.proofStrip.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="hero-visual panel inset">
      <img src={`${import.meta.env.BASE_URL}brand/arbinexus-logo.png`} alt="ArbiNexus brand mark" loading="eager" />
      <p>{content.footerTagline}</p>
    </div>
  </section>

  <section id="problem" class="panel split">
    <div>
      <p class="section-kicker">{content.sections.problem}</p>
      <h2>{content.problemTitle}</h2>
    </div>
    <div class="body-stack">
      {content.problemBody.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section id="how-it-works" class="panel">
    <p class="section-kicker">{content.sections.how}</p>
    <h2>{content.howTitle}</h2>
    <div class="step-grid">
      {content.howSteps.map((step, index) => (
        <article class="step-card inset">
          <span class="step-index">0{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="screenshots" class="panel">
    <div class="section-head">
      <div>
        <p class="section-kicker">{content.sections.screenshots}</p>
        <h2>{content.screenshotCaption}</h2>
      </div>
      <a class="text-link" href="https://github.com/rigocrypto/arbinexus#running-locally" target="_blank" rel="noreferrer">{localSetupLabel}</a>
    </div>
    <div class="shot-grid">
      {screenshots.map((shot, index) => (
        <figure class="shot-card inset">
          <button
            class="shot-trigger"
            type="button"
            data-gallery-trigger
            data-index={index}
            data-src={shot.src}
            data-alt={shot.alt}
            aria-label={`${galleryLabels.open}: ${shot.alt}`}
          >
            <img src={shot.src} alt={shot.alt} loading="lazy" />
          </button>
        </figure>
      ))}
    </div>
    <p class="gallery-hint">{galleryLabels.hint}</p>
  </section>

  <div class="gallery-lightbox" id="gallery-lightbox" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label={content.sections.screenshots}>
    <button class="lightbox-backdrop" type="button" data-gallery-close aria-label={galleryLabels.close}></button>
    <div class="lightbox-panel panel">
      <div class="lightbox-toolbar">
        <button type="button" data-gallery-prev>{galleryLabels.prev}</button>
        <button type="button" data-gallery-next>{galleryLabels.next}</button>
        <span class="toolbar-spacer"></span>
        <button type="button" data-gallery-zoom-out>{galleryLabels.zoomOut}</button>
        <button type="button" data-gallery-reset>{galleryLabels.reset}</button>
        <button type="button" data-gallery-zoom-in>{galleryLabels.zoomIn}</button>
        <button type="button" data-gallery-close>{galleryLabels.close}</button>
      </div>
      <div class="lightbox-stage" id="lightbox-stage">
        <img id="lightbox-image" src="" alt="" draggable="false" />
      </div>
      <p class="lightbox-caption" id="lightbox-caption"></p>
    </div>
  </div>

  <section id="demo" class="panel split demo-block">
    <div>
      <p class="section-kicker">{content.sections.demo}</p>
      <h2>{content.demoBlurb}</h2>
      <p>{demoParagraph}</p>
    </div>
    <div class="video-shell inset">
      <iframe
        src="https://www.youtube.com/embed/G2c4WNlbrwI"
        title="ArbiNexus demo video"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <section id="why-arbinexus" class="panel split">
    <div>
      <p class="section-kicker">{content.sections.why}</p>
      <h2>{content.differentiatorsTitle}</h2>
    </div>
    <ul class="feature-list">
      {content.differentiators.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section id="tech-stack" class="panel stack-grid">
    <div>
      <p class="section-kicker">{content.sections.stack}</p>
      <h2>{stackTitle}</h2>
    </div>
    <div class="mini-grid">
      {stackCards.map((card) => (
        <article class="mini-card inset"><h3>{card.title}</h3><p>{card.body}</p></article>
      ))}
    </div>
  </section>

  <section id="roadmap" class="panel split roadmap-block">
    <div>
      <p class="section-kicker">{content.sections.roadmap}</p>
      <h2>{content.roadmapTitle}</h2>
    </div>
    <div class="roadmap-grid">
      <article class="inset">
        <h3>{roadmapNearLabel}</h3>
        <ul class="plain-list">{content.roadmapNear.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="inset">
        <h3>{roadmapLongLabel}</h3>
        <ul class="plain-list">{content.roadmapLong.map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
  </section>
</div>

<script>
  (() => {
    const triggers = Array.from(document.querySelectorAll('[data-gallery-trigger]'));
    const lightbox = document.getElementById('gallery-lightbox');
    const image = document.getElementById('lightbox-image');
    const caption = document.getElementById('lightbox-caption');
    const stage = document.getElementById('lightbox-stage');
    if (!triggers.length || !lightbox || !image || !caption || !stage) return;

    const items = triggers.map((trigger) => ({
      src: trigger.getAttribute('data-src') || '',
      alt: trigger.getAttribute('data-alt') || ''
    }));

    let current = 0;
    let isOpen = false;
    let scale = 1;
    let x = 0;
    let y = 0;
    let dragging = false;
    let startX = 0;
    let startY = 0;

    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

    const renderTransform = () => {
      image.style.transform = `translate(${x}px, ${y}px) scale(${scale})`;
      image.style.cursor = scale > 1 ? (dragging ? 'grabbing' : 'grab') : 'zoom-in';
    };

    const resetView = () => {
      scale = 1;
      x = 0;
      y = 0;
      renderTransform();
    };

    const loadItem = (index) => {
      current = (index + items.length) % items.length;
      image.src = items[current].src;
      image.alt = items[current].alt;
      caption.textContent = items[current].alt;
      resetView();
    };

    const openLightbox = (index) => {
      loadItem(index);
      isOpen = true;
      lightbox.hidden = false;
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.classList.add('no-scroll');
    };

    const closeLightbox = () => {
      isOpen = false;
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('no-scroll');
    };

    const updateZoom = (delta) => {
      scale = clamp(scale + delta, 1, 4);
      if (scale === 1) {
        x = 0;
        y = 0;
      }
      renderTransform();
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => openLightbox(index));
    });

    lightbox.querySelectorAll('[data-gallery-close]').forEach((button) => {
      button.addEventListener('click', closeLightbox);
    });

    lightbox.querySelector('[data-gallery-prev]')?.addEventListener('click', () => loadItem(current - 1));
    lightbox.querySelector('[data-gallery-next]')?.addEventListener('click', () => loadItem(current + 1));
    lightbox.querySelector('[data-gallery-zoom-in]')?.addEventListener('click', () => updateZoom(0.25));
    lightbox.querySelector('[data-gallery-zoom-out]')?.addEventListener('click', () => updateZoom(-0.25));
    lightbox.querySelector('[data-gallery-reset]')?.addEventListener('click', resetView);

    stage.addEventListener('wheel', (event) => {
      if (!isOpen) return;
      event.preventDefault();
      updateZoom(event.deltaY < 0 ? 0.2 : -0.2);
    }, { passive: false });

    image.addEventListener('pointerdown', (event) => {
      if (scale <= 1) return;
      dragging = true;
      startX = event.clientX - x;
      startY = event.clientY - y;
      image.setPointerCapture(event.pointerId);
      renderTransform();
    });

    image.addEventListener('pointermove', (event) => {
      if (!dragging || scale <= 1) return;
      x = event.clientX - startX;
      y = event.clientY - startY;
      renderTransform();
    });

    image.addEventListener('pointerup', () => {
      dragging = false;
      renderTransform();
    });

    image.addEventListener('pointercancel', () => {
      dragging = false;
      renderTransform();
    });

    document.addEventListener('keydown', (event) => {
      if (!isOpen) return;
      if (event.key === 'Escape') closeLightbox();
      if (event.key === 'ArrowRight') loadItem(current + 1);
      if (event.key === 'ArrowLeft') loadItem(current - 1);
      if (event.key === '+' || event.key === '=') updateZoom(0.25);
      if (event.key === '-') updateZoom(-0.25);
      if (event.key === '0') resetView();
    });
  })();
</script>
